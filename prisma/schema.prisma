// WeddingPass — Prisma Schema
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum GuestSide {
  BRIDE
  GROOM
}

enum GuestTier {
  GENERAL
  VIP
  BACKSTAGE
}

enum GuestStatus {
  PENDING
  CONFIRMED
  DECLINED
  ENTERED
}

enum GiftStatus {
  PENDING
  PAID
  FAILED
}

enum UserRole {
  ORGANIZER
  COUPLE
  BRIDE_FAMILY
  GROOM_FAMILY
  GATE_STAFF
}

// ─────────────────────────────────────────────
// NextAuth models (required by @auth/prisma-adapter)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  phone         String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(GATE_STAFF)
  eventId       String?

  accounts Account[]
  sessions Session[]

  event Event? @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([eventId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// Core domain models
// ─────────────────────────────────────────────

model Event {
  id               String   @id @default(cuid())
  name             String
  date             DateTime
  venue            String
  capacity         Int
  coupleNames      String
  bridePhone       String
  groomPhone       String
  chainDepthLimit  Int      @default(2)
  chainBranchWidth Int      @default(1)

  guests       Guest[]
  gifts        Gift[]
  inviteChains InviteChain[]
  users        User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("events")
}

model Guest {
  id            String      @id @default(cuid())
  eventId       String
  name          String
  phone         String
  side          GuestSide
  tableNumber   Int?
  tier          GuestTier   @default(GENERAL)
  plusOneAllowed Boolean    @default(false)
  plusOneName   String?
  invitedById   String?
  chainDepth    Int         @default(0)
  status        GuestStatus @default(PENDING)
  qrToken       String      @unique @default(cuid())
  enteredAt     DateTime?

  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitedBy Guest?  @relation("GuestChain", fields: [invitedById], references: [id])
  invitees  Guest[] @relation("GuestChain")

  gifts Gift[]

  inviteChainAsInviter InviteChain[] @relation("ChainInviter")
  inviteChainAsInvitee InviteChain[] @relation("ChainInvitee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([phone])
  @@index([qrToken])
  @@index([status])
  @@index([side])
  @@index([invitedById])
  @@map("guests")
}

model Gift {
  id            String     @id @default(cuid())
  eventId       String
  guestId       String
  amount        Decimal    @db.Decimal(10, 3)
  currency      String     @default("KWD")
  message       String?    @db.Text
  paymentRef    String?    @unique
  paymentMethod String?
  status        GiftStatus @default(PENDING)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([guestId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("gifts")
}

model InviteChain {
  id        String @id @default(cuid())
  eventId   String
  inviterId String
  inviteeId String
  depth     Int

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  inviter Guest @relation("ChainInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee Guest @relation("ChainInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([inviterId, inviteeId])
  @@index([eventId])
  @@index([inviterId])
  @@index([inviteeId])
  @@map("invite_chains")
}
